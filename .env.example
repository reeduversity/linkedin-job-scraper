# ──────────────────────────────────────────────────────────
# LinkedIn Job Scraper — Environment Configuration
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────

# ── Apify (Required for scraping) ─────────────────────────
APIFY_TOKEN=your_apify_api_token_here
APIFY_ACTOR_ID=valig/linkedin-jobs-scraper
APIFY_POST_ACTOR_ID=datadoping/linkedin-posts-search-scraper

# ── PostgreSQL Database (Neon / Local) ────────────────────
# Option A: Neon Cloud (recommended for production)
# Get your URL from https://neon.tech → Dashboard → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/linkedin_jobs?sslmode=require

# Option B: Local PostgreSQL (for development only)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=linkedin_jobs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Scraper Settings ──────────────────────────────────────
MAX_RESULTS=100
SCHEDULE_INTERVAL=60          # minutes
SCRAPER_ENABLED=True
SCRAPER_MAX_INSTANCES=1

# ── API Settings ──────────────────────────────────────────
# Comma-separated list of allowed CORS origins (for frontend)
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── Export Paths ──────────────────────────────────────────
CSV_EXPORT_PATH=data/csv/jobs.csv
EXCEL_EXPORT_PATH=data/excel/jobs.xlsx

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_PATH=logs/app.log

