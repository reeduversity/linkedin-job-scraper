# Apify / LinkedIn Jobs Scraper configuration
APIFY_TOKEN=your_apify_token_here
APIFY_ACTOR_ID=your_apify_actor_id_here

# PostgreSQL configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=linkedin_jobs_db
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password

# Export configuration
CSV_EXPORT_PATH=data/csv/jobs.csv
EXCEL_EXPORT_PATH=data/excel/jobs.xlsx

# Logging configuration
LOG_LEVEL=INFO
LOG_PATH=logs/app.log

# Scraper / scheduler configuration
MAX_RESULTS=200
SCHEDULE_INTERVAL=60
